#!/usr/bin/env bash

# DevTool Manager (dtm) - Manage development tools like JDK, Maven, Gradle, Go
# Usage:
#   dtm [--yes|-y] [--json] [--quiet|-q] <command> ...
#
#   dtm pull <tool> <version>    - Download and install a tool version
#   dtm set <tool> <version>     - Set tool version globally (~/.dtmrc + current shell)
#   dtm use <tool> <version>     - Set tool version for current shell only (no persist)
#   dtm list <tool>              - List installed versions
#   dtm current <tool>           - Print the active version of a tool
#   dtm available <tool> [filter]- Query remote for installable versions
#   dtm update <tool>            - Bump active install to latest patch in series
#   dtm remove <tool> <version>  - Remove an installed version
#   dtm doctor                   - Diagnose dtm environment (deps, PATH, installs)
#   dtm self-update              - Update dtm itself (git pull in install dir)
#   dtm uninstall                - Remove dtm symlink, shell rc hooks, and config
#   dtm config home [path]       - Get or set the DTM_HOME directory
#
# Global flags:
#   --yes, -y     Assume "yes" to confirmation prompts (CI/scripting).
#   --json        Emit machine-readable JSON for current/list/available/doctor.
#   --quiet, -q   Suppress informational output. Warnings/errors still print.
#
# Color is auto-disabled when stdout is piped or NO_COLOR is set.

set -e

# Configuration
# DTM_HOME can be set via environment variable or will use default
# Priority: 1. DTM_HOME env var, 2. Value in ~/.dtmconfig, 3. Default
DTM_CONFIG="${HOME}/.dtmrc"
DTM_SETTINGS="${HOME}/.dtmconfig"

# Source ~/.dtmconfig unconditionally so persisted mirror/proxy overrides
# apply even when DTM_HOME is already set in env. Env DTM_HOME still wins
# over a value in the settings file (back-compat with prior behavior).
_dtm_env_home="${DTM_HOME:-}"
if [[ -f "$DTM_SETTINGS" ]]; then
    source "$DTM_SETTINGS"
fi
if [[ -n "$_dtm_env_home" ]]; then
    DTM_HOME="$_dtm_env_home"
fi
unset _dtm_env_home

# Set default if still not set
DTM_ROOT="${DTM_HOME:-${HOME}/development/devtools}"

# Create DTM_ROOT directory if it doesn't exist
mkdir -p "$DTM_ROOT"

# Mirror endpoints (override via env or ~/.dtmconfig). HTTPS_PROXY/HTTP_PROXY/
# NO_PROXY are honored natively by curl, so no extra wiring is needed for
# proxy support — set them in your shell or ~/.dtmconfig and they take effect.
: "${DTM_TEMURIN_API:=https://api.adoptium.net/v3}"
: "${DTM_MAVEN_REPO:=https://repo.maven.apache.org/maven2}"
: "${DTM_MAVEN_DIST:=https://archive.apache.org/dist/maven}"
: "${DTM_GRADLE_DIST:=https://services.gradle.org}"
: "${DTM_GO_DIST:=https://go.dev}"
: "${DTM_GO_CHECKSUM:=https://dl.google.com/go}"
: "${DTM_NODE_DIST:=https://nodejs.org/dist}"
: "${DTM_PBS_REPO:=https://api.github.com/repos/astral-sh/python-build-standalone}"
: "${DTM_PBS_DIST:=https://github.com/astral-sh/python-build-standalone/releases/download}"
: "${DTM_PBS_LATEST:=https://raw.githubusercontent.com/astral-sh/python-build-standalone/latest-release/latest-release.json}"
export DTM_TEMURIN_API DTM_MAVEN_REPO DTM_MAVEN_DIST \
       DTM_GRADLE_DIST DTM_GO_DIST DTM_GO_CHECKSUM DTM_NODE_DIST \
       DTM_PBS_REPO DTM_PBS_DIST DTM_PBS_LATEST

# Colors for output. Disabled when NO_COLOR is set (https://no-color.org) or
# when the relevant stream is not a TTY. Errors/warnings always go to stderr,
# so they decide based on stderr; info/success go to stdout.
if [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 1 ]]; then
    GREEN='' BLUE='' NC_OUT=''
else
    GREEN='\033[0;32m'
    BLUE='\033[0;34m'
    NC_OUT='\033[0m'
fi
if [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 2 ]]; then
    RED='' YELLOW='' NC_ERR=''
else
    RED='\033[0;31m'
    YELLOW='\033[1;33m'
    NC_ERR='\033[0m'
fi
# Backwards-compat alias for any module that referenced NC directly.
NC="$NC_OUT"

# Logging functions.
# - --json silences info/success/warn so stdout stays valid JSON.
# - --quiet (DTM_QUIET) silences info/success only; warnings/errors still print.
# - warnings and errors always go to stderr so piped stdout stays clean.
log_info() {
    [[ -n "$DTM_OUTPUT_JSON" || -n "$DTM_QUIET" ]] && return 0
    echo -e "${BLUE}[INFO]${NC_OUT} $1"
}

log_success() {
    [[ -n "$DTM_OUTPUT_JSON" || -n "$DTM_QUIET" ]] && return 0
    echo -e "${GREEN}[SUCCESS]${NC_OUT} $1"
}

log_warn() {
    [[ -n "$DTM_OUTPUT_JSON" ]] && return 0
    echo -e "${YELLOW}[WARN]${NC_ERR} $1" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC_ERR} $1" >&2
}

# Confirmation prompt that honours DTM_ASSUME_YES (--yes / -y).
# Usage: dtm_confirm "Reinstall? (y/N): "
# Returns 0 for yes, 1 for no.
dtm_confirm() {
    local prompt="$1"
    if [[ -n "$DTM_ASSUME_YES" ]]; then
        return 0
    fi
    if [[ ! -t 0 ]]; then
        log_error "Refusing to prompt on non-TTY (use --yes/-y to confirm)"
        return 1
    fi
    local reply
    read -p "$prompt" -n 1 -r reply
    echo
    [[ $reply =~ ^[Yy]$ ]]
}

# Maintain a `current` symlink under a tool root pointing at the active install.
# Usage: dtm_set_current_symlink <tool_root> <install_dir>
dtm_set_current_symlink() {
    local tool_root="$1" install_dir="$2"
    [[ -d "$tool_root" && -d "$install_dir" ]] || return 1
    ln -sfn "$install_dir" "${tool_root}/current"
}

# Resolve a path through any symlinks. Echoes the absolute target.
# Usage: dtm_resolved_path <path>
dtm_resolved_path() {
    local p="$1"
    [[ -e "$p" ]] || { echo "$p"; return 1; }
    if [[ -d "$p" ]]; then
        ( cd "$p" && pwd -P )
    else
        ( cd "$(dirname "$p")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$p")" )
    fi
}

# Emit a JSON array of strings from stdin (one item per line). Uses jq.
dtm_json_string_array() {
    jq -R . | jq -s .
}

# Emit a sorted list of versions (one per line on stdin). Indented in normal
# mode, JSON array of strings in --json mode.
dtm_emit_version_list() {
    if [[ -n "$DTM_OUTPUT_JSON" ]]; then
        dtm_json_string_array
    else
        sed 's/^/    /'
    fi
}

# Fetch a checksum from a sidecar URL (.sha256, .sha512, etc).
# Returns just the hex hash (first whitespace-separated token).
fetch_checksum_from_url() {
    local url="$1"
    local content
    content=$(curl -sL --fail "$url" 2>/dev/null) || return 1
    if [[ -z "$content" ]]; then
        return 1
    fi
    echo "$content" | head -1 | awk '{print $1}'
}

# Portable in-place sed (BSD/macOS sed needs an empty arg after -i).
dtm_sed_i() {
    if sed --version >/dev/null 2>&1; then
        sed -i "$@"
    else
        sed -i '' "$@"
    fi
}

# Check that a URL is reachable. Treats any 2xx/3xx as success.
# Usage: dtm_url_exists <url>
dtm_url_exists() {
    local url="$1"
    local code
    code=$(curl -sIL --max-time 15 -o /dev/null -w '%{http_code}' "$url" 2>/dev/null) || return 1
    [[ "$code" =~ ^[23][0-9][0-9]$ ]]
}

# Download a URL to a path with retry + resume.
# Usage: dtm_download <url> <output_path>
dtm_download() {
    local url="$1"
    local out="$2"
    curl -L --fail --progress-bar \
        --retry 3 --retry-delay 2 --retry-connrefused \
        --continue-at - \
        -o "$out" "$url"
}

# Acquire an exclusive lock for an install directory. Caller must call
# dtm_release_lock with the same path on success or failure.
# Usage: dtm_acquire_lock <lock_path>
dtm_acquire_lock() {
    local lock_path="$1"
    mkdir -p "$(dirname "$lock_path")"
    if command -v flock >/dev/null 2>&1; then
        exec 9>"$lock_path"
        if ! flock -n 9; then
            log_error "Another dtm process holds the lock: $lock_path"
            return 1
        fi
        return 0
    fi
    # Fallback: mkdir-based lock
    local tries=0
    while ! mkdir "$lock_path" 2>/dev/null; do
        tries=$((tries + 1))
        if (( tries > 60 )); then
            log_error "Could not acquire lock after 60s: $lock_path"
            return 1
        fi
        sleep 1
    done
    DTM_LOCK_MKDIR="$lock_path"
    return 0
}

dtm_release_lock() {
    local lock_path="$1"
    if command -v flock >/dev/null 2>&1; then
        exec 9>&- 2>/dev/null || true
        rm -f "$lock_path"
    else
        rmdir "$lock_path" 2>/dev/null || true
        unset DTM_LOCK_MKDIR
    fi
}

# Remove all dtm-managed PATH/export lines from .dtmrc that reference a given
# variable name (e.g. JAVA_HOME, MAVEN_HOME, GRADLE_HOME, GOROOT, GOPATH).
# Matches both unexpanded ${VAR} and bare $VAR forms, plus historical
# substring-based lines (e.g. lines literally containing "/java/" in the path).
# Usage: dtm_clean_dtmrc_for <var_name> [extra_substring ...]
dtm_clean_dtmrc_for() {
    local var="$1"; shift
    [[ -f "$DTM_CONFIG" ]] || return 0

    dtm_sed_i "/^export ${var}=/d" "$DTM_CONFIG"
    dtm_sed_i "/^export PATH=.*\\\${${var}}/d" "$DTM_CONFIG"
    dtm_sed_i "/^export PATH=.*\$${var}[^A-Z_]/d" "$DTM_CONFIG"

    local extra
    for extra in "$@"; do
        # Use | as delimiter so paths containing / don't break the regex.
        dtm_sed_i "\|^export PATH=.*${extra}|d" "$DTM_CONFIG"
    done
}

# Check required external dependencies. Fails early with a helpful message.
dtm_check_deps() {
    local missing=()
    command -v curl >/dev/null 2>&1 || missing+=("curl")
    command -v jq   >/dev/null 2>&1 || missing+=("jq")
    command -v tar  >/dev/null 2>&1 || missing+=("tar")
    if (( ${#missing[@]} > 0 )); then
        log_error "Missing required dependencies: ${missing[*]}"
        log_info "Install them via your package manager and retry."
        exit 1
    fi
}

# Verify a file's checksum.
# Usage: verify_checksum <file> <expected_hash> [algo]
# algo: sha256 (default), sha512, or sha1
verify_checksum() {
    local file="$1"
    local expected="$2"
    local algo="${3:-sha256}"
    local actual=""

    if [[ -z "$expected" ]]; then
        log_error "Expected checksum is empty"
        return 1
    fi

    case "$algo" in
        sha256)
            if command -v sha256sum >/dev/null 2>&1; then
                actual=$(sha256sum "$file" | awk '{print $1}')
            elif command -v shasum >/dev/null 2>&1; then
                actual=$(shasum -a 256 "$file" | awk '{print $1}')
            else
                log_error "No SHA-256 tool available (install coreutils or shasum)"
                return 1
            fi
            ;;
        sha512)
            if command -v sha512sum >/dev/null 2>&1; then
                actual=$(sha512sum "$file" | awk '{print $1}')
            elif command -v shasum >/dev/null 2>&1; then
                actual=$(shasum -a 512 "$file" | awk '{print $1}')
            else
                log_error "No SHA-512 tool available (install coreutils or shasum)"
                return 1
            fi
            ;;
        sha1)
            if command -v sha1sum >/dev/null 2>&1; then
                actual=$(sha1sum "$file" | awk '{print $1}')
            elif command -v shasum >/dev/null 2>&1; then
                actual=$(shasum -a 1 "$file" | awk '{print $1}')
            else
                log_error "No SHA-1 tool available (install coreutils or shasum)"
                return 1
            fi
            ;;
        *)
            log_error "Unsupported checksum algorithm: $algo"
            return 1
            ;;
    esac

    expected=$(echo "$expected" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
    actual=$(echo "$actual" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')

    if [[ "$actual" != "$expected" ]]; then
        log_error "Checksum mismatch"
        log_error "  Expected: $expected"
        log_error "  Actual:   $actual"
        return 1
    fi

    return 0
}


# Detect OS and architecture
detect_platform() {
    local os=$(uname -s | tr '[:upper:]' '[:lower:]')
    local arch=$(uname -m)

    case "$os" in
        linux*) OS="linux" ;;
        darwin*) OS="mac" ;;
        *) log_error "Unsupported OS: $os"; exit 1 ;;
    esac

    case "$arch" in
        x86_64|amd64) ARCH="x64" ;;
        aarch64|arm64) ARCH="aarch64" ;;
        *) log_error "Unsupported architecture: $arch"; exit 1 ;;
    esac
}

# Source the tool-specific modules
source_modules() {
    # Resolve symlink to get actual script location
    local script_path="${BASH_SOURCE[0]}"
    while [ -L "$script_path" ]; do
        script_path="$(readlink "$script_path")"
    done
    local script_dir="$(cd "$(dirname "$script_path")" && pwd)"

    if [[ -f "${script_dir}/modules/java.sh" ]]; then
        source "${script_dir}/modules/java.sh"
    fi

    if [[ -f "${script_dir}/modules/maven.sh" ]]; then
        source "${script_dir}/modules/maven.sh"
    fi

    if [[ -f "${script_dir}/modules/gradle.sh" ]]; then
        source "${script_dir}/modules/gradle.sh"
    fi

    if [[ -f "${script_dir}/modules/go.sh" ]]; then
        source "${script_dir}/modules/go.sh"
    fi

    if [[ -f "${script_dir}/modules/node.sh" ]]; then
        source "${script_dir}/modules/node.sh"
    fi

    if [[ -f "${script_dir}/modules/python.sh" ]]; then
        source "${script_dir}/modules/python.sh"
    fi
}

# Doctor command — diagnose dtm environment health.
doctor_command() {
    set +e
    local issues=0 warnings=0
    local -a json_problems=()
    local -a json_tools_keys=()
    local -a json_tools_vals=()

    _doctor_problem() {
        local sev="$1" msg="$2"
        if [[ -n "$DTM_OUTPUT_JSON" ]]; then
            json_problems+=("$(jq -nc --arg s "$sev" --arg m "$msg" '{severity:$s,message:$m}')")
        fi
    }

    log_info "Running dtm doctor..."

    log_info "[deps] checking required dependencies..."
    local missing=()
    local cmd
    for cmd in curl jq tar unzip; do
        command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
    done
    if (( ${#missing[@]} > 0 )); then
        log_error "  missing: ${missing[*]}"
        issues=$((issues+1))
        _doctor_problem error "missing dependencies: ${missing[*]}"
    else
        log_success "  curl, jq, tar, unzip all present"
    fi

    log_info "[home] DTM_HOME=$DTM_ROOT"
    if [[ ! -d "$DTM_ROOT" ]]; then
        log_error "  DTM_ROOT missing"
        issues=$((issues+1))
        _doctor_problem error "DTM_ROOT missing: $DTM_ROOT"
    elif [[ ! -w "$DTM_ROOT" ]]; then
        log_error "  DTM_ROOT not writable"
        issues=$((issues+1))
        _doctor_problem error "DTM_ROOT not writable: $DTM_ROOT"
    else
        log_success "  exists and writable"
    fi

    log_info "[dtmrc] $DTM_CONFIG"
    if [[ -f "$DTM_CONFIG" ]]; then
        if bash -n "$DTM_CONFIG" 2>/dev/null; then
            log_success "  syntax OK"
        else
            log_error "  syntax errors"
            issues=$((issues+1))
            _doctor_problem error "dtmrc syntax errors: $DTM_CONFIG"
        fi
    else
        log_info "  not present (no global pins)"
    fi

    log_warn "[wrapper] cannot verify dtm.sh is sourced from inside dtm; ensure your shell rc sources dtm.sh"
    warnings=$((warnings+1))
    _doctor_problem warn "cannot verify dtm.sh is sourced"

    local tool var_name tool_root bin_rel val resolved
    for tool in java maven gradle go node python; do
        case "$tool" in
            java)   var_name=JAVA_HOME;   tool_root="${DTM_ROOT}/java";   bin_rel=bin/java ;;
            maven)  var_name=MAVEN_HOME;  tool_root="${DTM_ROOT}/maven";  bin_rel=bin/mvn ;;
            gradle) var_name=GRADLE_HOME; tool_root="${DTM_ROOT}/gradle"; bin_rel=bin/gradle ;;
            go)     var_name=GOROOT;      tool_root="${DTM_ROOT}/go";     bin_rel=bin/go ;;
            node)   var_name=NODE_HOME;   tool_root="${DTM_ROOT}/node";   bin_rel=bin/node ;;
            python) var_name=PYTHON_HOME; tool_root="${DTM_ROOT}/python"; bin_rel=bin/python3 ;;
        esac
        log_info "[$tool]"

        local tool_active="" tool_active_path="" tool_in_path="false"
        local tool_valid=0 tool_broken=0

        if [[ ! -d "$tool_root" ]]; then
            log_info "  no installs"
            json_tools_keys+=("$tool")
            json_tools_vals+=("$(jq -nc \
                --arg var "$var_name" \
                '{installs:{valid:0,broken:0},active:null,active_path:null,var:$var,in_path:false}')")
            continue
        fi

        local d
        for d in "$tool_root"/*; do
            [[ -d "$d" ]] || continue
            [[ -L "$d" ]] && continue
            if [[ -x "$d/$bin_rel" ]]; then
                tool_valid=$((tool_valid+1))
            else
                log_warn "  broken install: $d"
                warnings=$((warnings+1))
                tool_broken=$((tool_broken+1))
                _doctor_problem warn "broken install: $d"
            fi
        done
        log_info "  installs: $tool_valid valid, $tool_broken broken"

        val="${!var_name:-}"
        if [[ -z "$val" ]]; then
            log_info "  $var_name not set"
        elif [[ "$val" != "$tool_root"/* ]]; then
            log_warn "  $var_name=$val (outside $tool_root, not managed by dtm)"
            warnings=$((warnings+1))
            _doctor_problem warn "$var_name not managed by dtm: $val"
        elif [[ ! -d "$val" ]]; then
            log_error "  $var_name -> missing dir $val"
            issues=$((issues+1))
            _doctor_problem error "$var_name target missing: $val"
        elif [[ ! -x "$val/$bin_rel" ]]; then
            log_error "  $var_name -> $val missing $bin_rel"
            issues=$((issues+1))
            _doctor_problem error "$var_name target missing $bin_rel: $val"
        else
            resolved="$(dtm_resolved_path "$val")"
            tool_active="$(basename "$resolved")"
            tool_active_path="$resolved"
            log_success "  active: $tool_active"
            case ":$PATH:" in
                *":$val/bin:"*)
                    log_success "  $val/bin in PATH"
                    tool_in_path="true"
                    ;;
                *)
                    log_error "  $val/bin not in PATH"
                    issues=$((issues+1))
                    _doctor_problem error "$val/bin not in PATH"
                    ;;
            esac
        fi

        json_tools_keys+=("$tool")
        json_tools_vals+=("$(jq -nc \
            --arg var "$var_name" \
            --argjson valid "$tool_valid" \
            --argjson broken "$tool_broken" \
            --arg active "$tool_active" \
            --arg active_path "$tool_active_path" \
            --argjson in_path "$tool_in_path" \
            '{installs:{valid:$valid,broken:$broken},
              active: (if $active == "" then null else $active end),
              active_path: (if $active_path == "" then null else $active_path end),
              var:$var,
              in_path:$in_path}')")
    done

    log_info "[symlinks] scanning $DTM_ROOT for broken symlinks..."
    local broken_links link
    broken_links=$(find "$DTM_ROOT" -xtype l 2>/dev/null)
    if [[ -n "$broken_links" ]]; then
        while IFS= read -r link; do
            log_warn "  broken symlink: $link"
            warnings=$((warnings+1))
            _doctor_problem warn "broken symlink: $link"
        done <<< "$broken_links"
    else
        log_success "  none"
    fi

    log_info "[orphans] checking top-level entries under $DTM_ROOT..."
    local known_re='^(java|maven|gradle|go|node|python|go-workspaces)$'
    local orphans=() entry name
    for entry in "$DTM_ROOT"/*; do
        [[ -e "$entry" ]] || continue
        name=$(basename "$entry")
        if ! [[ "$name" =~ $known_re ]]; then
            orphans+=("$entry")
        fi
    done
    if (( ${#orphans[@]} > 0 )); then
        local o
        for o in "${orphans[@]}"; do
            log_warn "  unknown: $o"
            warnings=$((warnings+1))
            _doctor_problem warn "orphan entry: $o"
        done
    else
        log_success "  none"
    fi

    log_info "[migration] checking for legacy nvm/pyenv installs..."
    local nvm_dir="${NVM_DIR:-${HOME}/.nvm}/versions/node"
    local pyenv_dir="${PYENV_ROOT:-${HOME}/.pyenv}/versions"
    local -a nvm_versions=() pyenv_versions=()
    local mv mclean
    if [[ -d "$nvm_dir" ]]; then
        for mv in "$nvm_dir"/*; do
            [[ -d "$mv" ]] || continue
            nvm_versions+=("$(basename "$mv")")
        done
    fi
    if [[ -d "$pyenv_dir" ]]; then
        for mv in "$pyenv_dir"/*; do
            [[ -d "$mv" ]] || continue
            mclean="$(basename "$mv")"
            [[ "$mclean" == "system" ]] && continue
            pyenv_versions+=("$mclean")
        done
    fi
    if (( ${#nvm_versions[@]} == 0 && ${#pyenv_versions[@]} == 0 )); then
        log_success "  none detected"
    fi
    if (( ${#nvm_versions[@]} > 0 )); then
        log_warn "  nvm: $nvm_dir (${#nvm_versions[@]} version(s))"
        warnings=$((warnings+1))
        for mv in "${nvm_versions[@]}"; do
            mclean="${mv#v}"
            log_warn "    $mv  ->  dtm pull node $mclean"
        done
        _doctor_problem warn "legacy nvm installs at $nvm_dir; reinstall via 'dtm pull node <version>'"
    fi
    if (( ${#pyenv_versions[@]} > 0 )); then
        log_warn "  pyenv: $pyenv_dir (${#pyenv_versions[@]} version(s))"
        warnings=$((warnings+1))
        for mv in "${pyenv_versions[@]}"; do
            if [[ "$mv" =~ ^[0-9]+\.[0-9]+(\.[0-9]+)?$ ]]; then
                log_warn "    $mv  ->  dtm pull python $mv"
            else
                log_warn "    $mv  (skip: dtm only ships CPython via python-build-standalone)"
            fi
        done
        _doctor_problem warn "legacy pyenv installs at $pyenv_dir; reinstall CPython versions via 'dtm pull python <version>'"
    fi

    local migration_json
    if [[ -n "$DTM_OUTPUT_JSON" ]]; then
        local nvm_arr="[]" pyenv_arr="[]"
        if (( ${#nvm_versions[@]} > 0 )); then
            nvm_arr=$(printf '%s\n' "${nvm_versions[@]}" | jq -R . | jq -s .)
        fi
        if (( ${#pyenv_versions[@]} > 0 )); then
            pyenv_arr=$(printf '%s\n' "${pyenv_versions[@]}" | jq -R . | jq -s .)
        fi
        migration_json=$(jq -nc \
            --arg nvm_path "$nvm_dir" \
            --arg pyenv_path "$pyenv_dir" \
            --argjson nvm_versions "$nvm_arr" \
            --argjson pyenv_versions "$pyenv_arr" \
            '{nvm:   {path:$nvm_path,   detected:($nvm_versions   | length > 0), versions:$nvm_versions},
              pyenv: {path:$pyenv_path, detected:($pyenv_versions | length > 0), versions:$pyenv_versions}}')
    fi

    log_info "[network] proxy + mirror configuration"
    local proxy_https="${HTTPS_PROXY:-${https_proxy:-}}"
    local proxy_http="${HTTP_PROXY:-${http_proxy:-}}"
    local proxy_no="${NO_PROXY:-${no_proxy:-}}"
    if [[ -n "$proxy_https" ]]; then
        log_info "  HTTPS_PROXY=$proxy_https"
    fi
    if [[ -n "$proxy_http" ]]; then
        log_info "  HTTP_PROXY=$proxy_http"
    fi
    if [[ -n "$proxy_no" ]]; then
        log_info "  NO_PROXY=$proxy_no"
    fi
    if [[ -z "$proxy_https" && -z "$proxy_http" ]]; then
        log_info "  no proxy configured (HTTPS_PROXY/HTTP_PROXY unset)"
    fi

    local -A _mirror_defaults=(
        [DTM_TEMURIN_API]="https://api.adoptium.net/v3"
        [DTM_MAVEN_REPO]="https://repo.maven.apache.org/maven2"
        [DTM_MAVEN_DIST]="https://archive.apache.org/dist/maven"
        [DTM_GRADLE_DIST]="https://services.gradle.org"
        [DTM_GO_DIST]="https://go.dev"
        [DTM_GO_CHECKSUM]="https://dl.google.com/go"
        [DTM_NODE_DIST]="https://nodejs.org/dist"
        [DTM_PBS_REPO]="https://api.github.com/repos/astral-sh/python-build-standalone"
        [DTM_PBS_DIST]="https://github.com/astral-sh/python-build-standalone/releases/download"
        [DTM_PBS_LATEST]="https://raw.githubusercontent.com/astral-sh/python-build-standalone/latest-release/latest-release.json"
    )
    local -a _mirror_order=(DTM_TEMURIN_API DTM_MAVEN_REPO DTM_MAVEN_DIST \
                            DTM_GRADLE_DIST DTM_GO_DIST DTM_GO_CHECKSUM \
                            DTM_NODE_DIST DTM_PBS_REPO DTM_PBS_DIST \
                            DTM_PBS_LATEST)
    local mvar mval mdef
    for mvar in "${_mirror_order[@]}"; do
        mval="${!mvar}"
        mdef="${_mirror_defaults[$mvar]}"
        if [[ "$mval" != "$mdef" ]]; then
            log_info "  $mvar=$mval (overridden)"
        else
            log_info "  $mvar=$mval"
        fi
    done

    if [[ -n "$DTM_OUTPUT_JSON" ]]; then
        local tools_json="{}"
        local i
        for (( i=0; i < ${#json_tools_keys[@]}; i++ )); do
            tools_json=$(jq -c \
                --arg k "${json_tools_keys[$i]}" \
                --argjson v "${json_tools_vals[$i]}" \
                '. + {($k):$v}' <<< "$tools_json")
        done
        local problems_json="[]"
        if (( ${#json_problems[@]} > 0 )); then
            problems_json=$(printf '%s\n' "${json_problems[@]}" | jq -s .)
        fi
        local mirrors_json="{}"
        for mvar in "${_mirror_order[@]}"; do
            mval="${!mvar}"
            mdef="${_mirror_defaults[$mvar]}"
            mirrors_json=$(jq -c \
                --arg k "$mvar" \
                --arg url "$mval" \
                --argjson overridden "$([[ "$mval" != "$mdef" ]] && echo true || echo false)" \
                '. + {($k): {url:$url, overridden:$overridden}}' <<< "$mirrors_json")
        done
        local network_json
        network_json=$(jq -nc \
            --arg https "$proxy_https" \
            --arg http "$proxy_http" \
            --arg no "$proxy_no" \
            --argjson mirrors "$mirrors_json" \
            '{proxy: {https: (if $https=="" then null else $https end),
                      http:  (if $http=="" then null else $http end),
                      no:    (if $no=="" then null else $no end)},
              mirrors:$mirrors}')
        jq -n \
            --argjson errors "$issues" \
            --argjson warnings "$warnings" \
            --argjson tools "$tools_json" \
            --argjson problems "$problems_json" \
            --argjson network "$network_json" \
            --argjson migration "$migration_json" \
            --arg dtm_home "$DTM_ROOT" \
            --arg dtmrc "$DTM_CONFIG" \
            '{ok: ($errors == 0), errors:$errors, warnings:$warnings,
              dtm_home:$dtm_home, dtmrc:$dtmrc, tools:$tools,
              network:$network, migration:$migration, problems:$problems}'
        if (( issues > 0 )); then exit 1; fi
        return 0
    fi

    echo ""
    if (( issues > 0 )); then
        log_error "doctor: $issues error(s), $warnings warning(s)"
        exit 1
    fi
    log_success "doctor: 0 errors, $warnings warning(s)"
}

# Resolve dtm's install directory by following BASH_SOURCE through any symlinks.
dtm_install_dir() {
    local script_path="${BASH_SOURCE[0]}"
    while [ -L "$script_path" ]; do
        local link_target
        link_target="$(readlink "$script_path")"
        if [[ "$link_target" = /* ]]; then
            script_path="$link_target"
        else
            script_path="$(cd "$(dirname "$script_path")" && pwd)/$link_target"
        fi
    done
    cd "$(dirname "$script_path")" && pwd
}

# Self-update — git pull in dtm's install directory.
self_update_command() {
    if ! command -v git >/dev/null 2>&1; then
        log_error "git is required for self-update"
        exit 1
    fi

    local install_dir
    install_dir="$(dtm_install_dir)"
    log_info "dtm install dir: $install_dir"

    if [[ ! -d "$install_dir/.git" ]]; then
        log_error "Not a git checkout: $install_dir"
        log_info "self-update requires dtm to be installed via 'git clone'"
        exit 1
    fi

    if ! git -C "$install_dir" diff --quiet || ! git -C "$install_dir" diff --cached --quiet; then
        log_error "Uncommitted changes in $install_dir"
        log_info "Commit, stash, or reset them before self-update"
        exit 1
    fi

    local before after branch
    branch="$(git -C "$install_dir" rev-parse --abbrev-ref HEAD)"
    before="$(git -C "$install_dir" rev-parse HEAD)"
    log_info "Pulling on branch '$branch'..."

    if ! git -C "$install_dir" pull --ff-only; then
        log_error "git pull failed (non-fast-forward or network error)"
        exit 1
    fi

    after="$(git -C "$install_dir" rev-parse HEAD)"
    if [[ "$before" == "$after" ]]; then
        log_success "Already up to date ($before)"
        return 0
    fi

    log_success "Updated $branch: ${before:0:12} -> ${after:0:12}"
    log_info "Changes:"
    git -C "$install_dir" log --oneline "${before}..${after}"
}

# Strip lines matching a regex from a file. No-op if file missing or no match.
# Uses dtm_sed_i for portability between GNU and BSD sed.
dtm_strip_lines() {
    local file="$1" pattern="$2"
    [[ -f "$file" ]] || return 0
    grep -qE "$pattern" "$file" 2>/dev/null || return 0
    dtm_sed_i "/${pattern//\//\\/}/d" "$file"
    log_info "  cleaned: $file"
}

# Uninstall — remove dtm shim symlinks, shell rc hooks, and configuration.
# Leaves the dtm install directory (the git checkout) and DTM_ROOT untouched
# unless the user explicitly opts in. Idempotent: safe to re-run.
uninstall_command() {
    local install_dir
    install_dir="$(dtm_install_dir)"
    log_info "dtm install dir: $install_dir (will not be deleted)"
    log_info "DTM_ROOT:        $DTM_ROOT (will not be deleted unless requested)"

    if ! dtm_confirm "Proceed with uninstall? (y/N): "; then
        log_info "Aborted."
        return 0
    fi

    log_info "[shim] removing ~/.local/bin/dtm"
    if [[ -L "${HOME}/.local/bin/dtm" || -e "${HOME}/.local/bin/dtm" ]]; then
        rm -f "${HOME}/.local/bin/dtm"
        log_success "  removed"
    else
        log_info "  not present"
    fi

    log_info "[shell-rc] cleaning sourced hooks"
    local rc
    for rc in "${HOME}/.bashrc" "${HOME}/.zshrc" "${HOME}/.kshrc" \
              "${HOME}/.config/fish/config.fish"; do
        [[ -f "$rc" ]] || continue
        # Match any line that references dtm.sh, dtm completion files, the
        # ~/.dtmrc/.dtmconfig sourcing helpers, or the dtm header comments
        # written by install.sh.
        dtm_strip_lines "$rc" '^# DevTool Manager'
        dtm_strip_lines "$rc" 'source.*dtm\.sh'
        dtm_strip_lines "$rc" 'completions/dtm\.bash'
        dtm_strip_lines "$rc" 'completions/_dtm'
        dtm_strip_lines "$rc" 'completions/dtm\.fish'
        dtm_strip_lines "$rc" 'source.*\.dtmrc'
        dtm_strip_lines "$rc" 'source.*\.dtmconfig'
    done

    log_info "[completions] removing installed completion files"
    local f
    for f in "${HOME}/.zsh/completions/_dtm" \
             "${HOME}/.config/fish/completions/dtm.fish"; do
        if [[ -L "$f" || -e "$f" ]]; then
            rm -f "$f"
            log_success "  removed: $f"
        fi
    done

    log_info "[config] removing $DTM_CONFIG and $DTM_SETTINGS"
    rm -f "$DTM_CONFIG" "$DTM_SETTINGS"
    log_success "  removed"

    if [[ -d "$DTM_ROOT" ]]; then
        if dtm_confirm "Also delete installed tools under $DTM_ROOT? (y/N): "; then
            log_info "[home] removing $DTM_ROOT"
            rm -rf "$DTM_ROOT"
            log_success "  removed"
        else
            log_info "Kept $DTM_ROOT (delete manually if you wish)"
        fi
    fi

    log_success "dtm uninstalled."
    log_info "To finish: restart your shell (rc files were edited)."
    log_info "The dtm checkout itself is still at: $install_dir"
}

# Config command handler
config_command() {
    local subcommand="$1"
    local value="$2"

    case "$subcommand" in
        home)
            if [[ -z "$value" ]]; then
                # Show current DTM_HOME
                log_info "Current DTM_HOME: $DTM_ROOT"
                if [[ -n "$DTM_HOME" ]]; then
                    log_info "  (set via DTM_HOME environment variable)"
                elif [[ -f "$DTM_SETTINGS" ]]; then
                    log_info "  (set via $DTM_SETTINGS)"
                else
                    log_info "  (using default)"
                fi
            else
                # Set new DTM_HOME
                local new_path="$value"

                # Expand ~ to home directory
                new_path="${new_path/#\~/$HOME}"

                # Convert to absolute path
                new_path=$(realpath -m "$new_path")

                log_info "Setting DTM_HOME to: $new_path"

                # Create the directory if it doesn't exist
                mkdir -p "$new_path"

                # Save to settings file
                echo "# DevTool Manager Configuration" > "$DTM_SETTINGS"
                echo "# This file is sourced by dtm to set configuration" >> "$DTM_SETTINGS"
                echo "export DTM_HOME=\"$new_path\"" >> "$DTM_SETTINGS"

                log_success "DTM_HOME configured successfully"
                log_info "Restart your shell or run: source ~/.dtmconfig"
                log_info "Current session still uses: $DTM_ROOT"
            fi
            ;;
        *)
            log_error "Unknown config subcommand: $subcommand"
            echo "Available subcommands: home"
            exit 1
            ;;
    esac
}

# Main command dispatcher
main() {
    # Parse global flags. Accept them anywhere in the argument list so users
    # can write either `dtm --yes pull java 21` or `dtm pull java 21 --yes`.
    local -a args=()
    local a
    for a in "$@"; do
        case "$a" in
            -y|--yes)   export DTM_ASSUME_YES=1 ;;
            --json)     export DTM_OUTPUT_JSON=1 ;;
            -q|--quiet) export DTM_QUIET=1 ;;
            *)          args+=("$a") ;;
        esac
    done
    set -- "${args[@]}"

    if [[ $# -lt 1 ]]; then
        show_usage
        exit 1
    fi

    local command="$1"

    # Handle config command separately (different argument structure)
    if [[ "$command" == "config" ]]; then
        if [[ $# -lt 2 ]]; then
            log_error "Config subcommand required"
            echo "Available subcommands: home"
            exit 1
        fi
        config_command "$2" "$3"
        exit 0
    fi

    # Handle doctor command separately (no tool/version args)
    if [[ "$command" == "doctor" ]]; then
        detect_platform
        source_modules
        doctor_command
        exit 0
    fi

    # Handle self-update separately (no tool/version args, no module load)
    if [[ "$command" == "self-update" ]]; then
        self_update_command
        exit 0
    fi

    # Handle uninstall separately (no tool/version args, no module load)
    if [[ "$command" == "uninstall" ]]; then
        uninstall_command
        exit 0
    fi

    # All other commands require at least tool argument
    if [[ $# -lt 2 ]]; then
        show_usage
        exit 1
    fi

    local tool="$2"
    local version="$3"

    detect_platform
    source_modules

    # Warn when set/use/update is invoked outside the dtm.sh wrapper. These
    # commands emit `export ...` lines on stdout that the wrapper eval's into
    # the parent shell. Without the wrapper, the user sees the lines but PATH
    # never changes — looks successful, isn't. The wrapper sets DTM_WRAPPED=1
    # before invoking us, so its absence + a TTY stdout (i.e. user is reading
    # the output, not piping it into eval) is the misuse signal. The warning
    # goes to stderr so it never breaks intentional `eval "$(dtm set ...)"`.
    case "$command" in
        set|use|update)
            if [[ -z "${DTM_WRAPPED:-}" && -t 1 ]]; then
                log_warn "dtm.sh wrapper not detected — exports printed below will not"
                log_warn "be applied to your shell. Either source dtm.sh from your shell"
                log_warn "rc, or run: eval \"\$(dtm $command $tool${version:+ $version})\""
            fi
            ;;
    esac

    case "$command" in
        pull)
            if [[ -z "$version" ]]; then
                log_error "Version is required for pull command"
                exit 1
            fi

            dtm_check_deps

            case "$tool" in
                java) pull_java "$version" ;;
                maven) pull_maven "$version" ;;
                gradle) pull_gradle "$version" ;;
                go) pull_go "$version" ;;
                node) pull_node "$version" ;;
                python) pull_python "$version" ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        set)
            if [[ -z "$version" ]]; then
                log_error "Version is required for set command"
                exit 1
            fi

            case "$tool" in
                java) set_java "$version" set ;;
                maven) set_maven "$version" set ;;
                gradle) set_gradle "$version" set ;;
                go) set_go "$version" set ;;
                node) set_node "$version" set ;;
                python) set_python "$version" set ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        use)
            if [[ -z "$version" ]]; then
                log_error "Version is required for use command"
                exit 1
            fi

            case "$tool" in
                java) set_java "$version" use ;;
                maven) set_maven "$version" use ;;
                gradle) set_gradle "$version" use ;;
                go) set_go "$version" use ;;
                node) set_node "$version" use ;;
                python) set_python "$version" use ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        list)
            case "$tool" in
                java) list_java ;;
                maven) list_maven ;;
                gradle) list_gradle ;;
                go) list_go ;;
                node) list_node ;;
                python) list_python ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        current)
            case "$tool" in
                java) current_java ;;
                maven) current_maven ;;
                gradle) current_gradle ;;
                go) current_go ;;
                node) current_node ;;
                python) current_python ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        available)
            dtm_check_deps
            case "$tool" in
                java) available_java "$version" ;;
                maven) available_maven "$version" ;;
                gradle) available_gradle "$version" ;;
                go) available_go "$version" ;;
                node) available_node "$version" ;;
                python) available_python "$version" ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        remove)
            if [[ -z "$version" ]]; then
                log_error "Version is required for remove command"
                exit 1
            fi

            case "$tool" in
                java) remove_java "$version" ;;
                maven) remove_maven "$version" ;;
                gradle) remove_gradle "$version" ;;
                go) remove_go "$version" ;;
                node) remove_node "$version" ;;
                python) remove_python "$version" ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        update)
            dtm_check_deps
            case "$tool" in
                java) update_java ;;
                maven) update_maven ;;
                gradle) update_gradle ;;
                go) update_go ;;
                node) update_node ;;
                python) update_python ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        *)
            log_error "Unknown command: $command"
            show_usage
            exit 1
            ;;
    esac
}

main "$@"

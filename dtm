#!/usr/bin/env bash

# DevTool Manager (dtm) - Manage development tools like JDK, Maven, Gradle, Go
# Usage:
#   dtm pull <tool> <version>    - Download and install a tool version
#   dtm set <tool> <version>     - Set PATH and environment variables for a tool version
#   dtm list <tool>              - List installed versions
#   dtm remove <tool> <version>  - Remove an installed version
#   dtm config home [path]       - Get or set the DTM_HOME directory

set -e

# Configuration
# DTM_HOME can be set via environment variable or will use default
# Priority: 1. DTM_HOME env var, 2. Value in ~/.dtmconfig, 3. Default
DTM_CONFIG="${HOME}/.dtmrc"
DTM_SETTINGS="${HOME}/.dtmconfig"

# Load DTM_HOME from settings file if it exists and DTM_HOME is not set
if [[ -z "$DTM_HOME" && -f "$DTM_SETTINGS" ]]; then
    source "$DTM_SETTINGS"
fi

# Set default if still not set
DTM_ROOT="${DTM_HOME:-${HOME}/development/devtools}"

# Create DTM_ROOT directory if it doesn't exist
mkdir -p "$DTM_ROOT"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Fetch a checksum from a sidecar URL (.sha256, .sha512, etc).
# Returns just the hex hash (first whitespace-separated token).
fetch_checksum_from_url() {
    local url="$1"
    local content
    content=$(curl -sL --fail "$url" 2>/dev/null) || return 1
    if [[ -z "$content" ]]; then
        return 1
    fi
    echo "$content" | head -1 | awk '{print $1}'
}

# Portable in-place sed (BSD/macOS sed needs an empty arg after -i).
dtm_sed_i() {
    if sed --version >/dev/null 2>&1; then
        sed -i "$@"
    else
        sed -i '' "$@"
    fi
}

# Check that a URL is reachable. Treats any 2xx/3xx as success.
# Usage: dtm_url_exists <url>
dtm_url_exists() {
    local url="$1"
    local code
    code=$(curl -sIL --max-time 15 -o /dev/null -w '%{http_code}' "$url" 2>/dev/null) || return 1
    [[ "$code" =~ ^[23][0-9][0-9]$ ]]
}

# Download a URL to a path with retry + resume.
# Usage: dtm_download <url> <output_path>
dtm_download() {
    local url="$1"
    local out="$2"
    curl -L --fail --progress-bar \
        --retry 3 --retry-delay 2 --retry-connrefused \
        --continue-at - \
        -o "$out" "$url"
}

# Acquire an exclusive lock for an install directory. Caller must call
# dtm_release_lock with the same path on success or failure.
# Usage: dtm_acquire_lock <lock_path>
dtm_acquire_lock() {
    local lock_path="$1"
    mkdir -p "$(dirname "$lock_path")"
    if command -v flock >/dev/null 2>&1; then
        exec 9>"$lock_path"
        if ! flock -n 9; then
            log_error "Another dtm process holds the lock: $lock_path"
            return 1
        fi
        return 0
    fi
    # Fallback: mkdir-based lock
    local tries=0
    while ! mkdir "$lock_path" 2>/dev/null; do
        tries=$((tries + 1))
        if (( tries > 60 )); then
            log_error "Could not acquire lock after 60s: $lock_path"
            return 1
        fi
        sleep 1
    done
    DTM_LOCK_MKDIR="$lock_path"
    return 0
}

dtm_release_lock() {
    local lock_path="$1"
    if command -v flock >/dev/null 2>&1; then
        exec 9>&- 2>/dev/null || true
        rm -f "$lock_path"
    else
        rmdir "$lock_path" 2>/dev/null || true
        unset DTM_LOCK_MKDIR
    fi
}

# Remove all dtm-managed PATH/export lines from .dtmrc that reference a given
# variable name (e.g. JAVA_HOME, MAVEN_HOME, GRADLE_HOME, GOROOT, GOPATH).
# Matches both unexpanded ${VAR} and bare $VAR forms, plus historical
# substring-based lines (e.g. lines literally containing "/java/" in the path).
# Usage: dtm_clean_dtmrc_for <var_name> [extra_substring ...]
dtm_clean_dtmrc_for() {
    local var="$1"; shift
    [[ -f "$DTM_CONFIG" ]] || return 0

    dtm_sed_i "/^export ${var}=/d" "$DTM_CONFIG"
    dtm_sed_i "/^export PATH=.*\\\${${var}}/d" "$DTM_CONFIG"
    dtm_sed_i "/^export PATH=.*\$${var}[^A-Z_]/d" "$DTM_CONFIG"

    local extra
    for extra in "$@"; do
        # Use | as delimiter so paths containing / don't break the regex.
        dtm_sed_i "\|^export PATH=.*${extra}|d" "$DTM_CONFIG"
    done
}

# Check required external dependencies. Fails early with a helpful message.
dtm_check_deps() {
    local missing=()
    command -v curl >/dev/null 2>&1 || missing+=("curl")
    command -v jq   >/dev/null 2>&1 || missing+=("jq")
    command -v tar  >/dev/null 2>&1 || missing+=("tar")
    if (( ${#missing[@]} > 0 )); then
        log_error "Missing required dependencies: ${missing[*]}"
        log_info "Install them via your package manager and retry."
        exit 1
    fi
}

# Verify a file's checksum.
# Usage: verify_checksum <file> <expected_hash> [algo]
# algo: sha256 (default) or sha512
verify_checksum() {
    local file="$1"
    local expected="$2"
    local algo="${3:-sha256}"
    local actual=""

    if [[ -z "$expected" ]]; then
        log_error "Expected checksum is empty"
        return 1
    fi

    case "$algo" in
        sha256)
            if command -v sha256sum >/dev/null 2>&1; then
                actual=$(sha256sum "$file" | awk '{print $1}')
            elif command -v shasum >/dev/null 2>&1; then
                actual=$(shasum -a 256 "$file" | awk '{print $1}')
            else
                log_error "No SHA-256 tool available (install coreutils or shasum)"
                return 1
            fi
            ;;
        sha512)
            if command -v sha512sum >/dev/null 2>&1; then
                actual=$(sha512sum "$file" | awk '{print $1}')
            elif command -v shasum >/dev/null 2>&1; then
                actual=$(shasum -a 512 "$file" | awk '{print $1}')
            else
                log_error "No SHA-512 tool available (install coreutils or shasum)"
                return 1
            fi
            ;;
        *)
            log_error "Unsupported checksum algorithm: $algo"
            return 1
            ;;
    esac

    expected=$(echo "$expected" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
    actual=$(echo "$actual" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')

    if [[ "$actual" != "$expected" ]]; then
        log_error "Checksum mismatch"
        log_error "  Expected: $expected"
        log_error "  Actual:   $actual"
        return 1
    fi

    return 0
}

# Show usage
show_usage() {
    cat << EOF
DevTool Manager (dtm) - Manage development tools

Usage:
  dtm pull <tool> <version>       Download and install a tool version
  dtm set <tool> <version>        Set PATH and environment for a tool
  dtm list <tool>                 List installed versions
  dtm remove <tool> <version>     Remove an installed version
  dtm config home [path]          Get or set the DTM_HOME directory

Supported tools:
  java    - JDK from Eclipse Temurin
  maven   - Apache Maven
  gradle  - Gradle Build Tool
  go      - Go Programming Language
  node    - Node.js (via nvm)
  python  - Python (via pyenv)

Examples:
  dtm pull java 11              Pull latest Java 11
  dtm pull java 11.0.29         Pull specific Java 11.0.29
  dtm set java 11               Set Java 11 as active
  dtm list java                 List installed Java versions
  dtm config home               Show current DTM_HOME path
  dtm config home /custom/path  Set DTM_HOME to /custom/path
EOF
}

# Detect OS and architecture
detect_platform() {
    local os=$(uname -s | tr '[:upper:]' '[:lower:]')
    local arch=$(uname -m)

    case "$os" in
        linux*) OS="linux" ;;
        darwin*) OS="mac" ;;
        *) log_error "Unsupported OS: $os"; exit 1 ;;
    esac

    case "$arch" in
        x86_64|amd64) ARCH="x64" ;;
        aarch64|arm64) ARCH="aarch64" ;;
        *) log_error "Unsupported architecture: $arch"; exit 1 ;;
    esac
}

# Source the tool-specific modules
source_modules() {
    # Resolve symlink to get actual script location
    local script_path="${BASH_SOURCE[0]}"
    while [ -L "$script_path" ]; do
        script_path="$(readlink "$script_path")"
    done
    local script_dir="$(cd "$(dirname "$script_path")" && pwd)"

    if [[ -f "${script_dir}/modules/java.sh" ]]; then
        source "${script_dir}/modules/java.sh"
    fi

    if [[ -f "${script_dir}/modules/maven.sh" ]]; then
        source "${script_dir}/modules/maven.sh"
    fi

    if [[ -f "${script_dir}/modules/gradle.sh" ]]; then
        source "${script_dir}/modules/gradle.sh"
    fi

    if [[ -f "${script_dir}/modules/go.sh" ]]; then
        source "${script_dir}/modules/go.sh"
    fi

    if [[ -f "${script_dir}/modules/node.sh" ]]; then
        source "${script_dir}/modules/node.sh"
    fi

    if [[ -f "${script_dir}/modules/python.sh" ]]; then
        source "${script_dir}/modules/python.sh"
    fi
}

# Config command handler
config_command() {
    local subcommand="$1"
    local value="$2"

    case "$subcommand" in
        home)
            if [[ -z "$value" ]]; then
                # Show current DTM_HOME
                log_info "Current DTM_HOME: $DTM_ROOT"
                if [[ -n "$DTM_HOME" ]]; then
                    log_info "  (set via DTM_HOME environment variable)"
                elif [[ -f "$DTM_SETTINGS" ]]; then
                    log_info "  (set via $DTM_SETTINGS)"
                else
                    log_info "  (using default)"
                fi
            else
                # Set new DTM_HOME
                local new_path="$value"

                # Expand ~ to home directory
                new_path="${new_path/#\~/$HOME}"

                # Convert to absolute path
                new_path=$(realpath -m "$new_path")

                log_info "Setting DTM_HOME to: $new_path"

                # Create the directory if it doesn't exist
                mkdir -p "$new_path"

                # Save to settings file
                echo "# DevTool Manager Configuration" > "$DTM_SETTINGS"
                echo "# This file is sourced by dtm to set configuration" >> "$DTM_SETTINGS"
                echo "export DTM_HOME=\"$new_path\"" >> "$DTM_SETTINGS"

                log_success "DTM_HOME configured successfully"
                log_info "Restart your shell or run: source ~/.dtmconfig"
                log_info "Current session still uses: $DTM_ROOT"
            fi
            ;;
        *)
            log_error "Unknown config subcommand: $subcommand"
            echo "Available subcommands: home"
            exit 1
            ;;
    esac
}

# Main command dispatcher
main() {
    if [[ $# -lt 1 ]]; then
        show_usage
        exit 1
    fi

    local command="$1"

    # Handle config command separately (different argument structure)
    if [[ "$command" == "config" ]]; then
        if [[ $# -lt 2 ]]; then
            log_error "Config subcommand required"
            echo "Available subcommands: home"
            exit 1
        fi
        config_command "$2" "$3"
        exit 0
    fi

    # All other commands require at least tool argument
    if [[ $# -lt 2 ]]; then
        show_usage
        exit 1
    fi

    local tool="$2"
    local version="$3"

    detect_platform
    source_modules

    case "$command" in
        pull)
            if [[ -z "$version" ]]; then
                log_error "Version is required for pull command"
                exit 1
            fi

            dtm_check_deps

            case "$tool" in
                java) pull_java "$version" ;;
                maven) pull_maven "$version" ;;
                gradle) pull_gradle "$version" ;;
                go) pull_go "$version" ;;
                node) pull_node "$version" ;;
                python) pull_python "$version" ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        set)
            if [[ -z "$version" ]]; then
                log_error "Version is required for set command"
                exit 1
            fi

            case "$tool" in
                java) set_java "$version" ;;
                maven) set_maven "$version" ;;
                gradle) set_gradle "$version" ;;
                go) set_go "$version" ;;
                node) set_node "$version" ;;
                python) set_python "$version" ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        list)
            case "$tool" in
                java) list_java ;;
                maven) list_maven ;;
                gradle) list_gradle ;;
                go) list_go ;;
                node) list_node ;;
                python) list_python ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        remove)
            if [[ -z "$version" ]]; then
                log_error "Version is required for remove command"
                exit 1
            fi

            case "$tool" in
                java) remove_java "$version" ;;
                maven) remove_maven "$version" ;;
                gradle) remove_gradle "$version" ;;
                go) remove_go "$version" ;;
                node) remove_node "$version" ;;
                python) remove_python "$version" ;;
                *) log_error "Unknown tool: $tool"; exit 1 ;;
            esac
            ;;
        *)
            log_error "Unknown command: $command"
            show_usage
            exit 1
            ;;
    esac
}

main "$@"
